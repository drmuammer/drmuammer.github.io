<div class="note-list">
<% for (const item of items) { %>
<article class="note-entry">
<div class="note-stamp">
<% if (item.date) { %>
<%
const months = ['Ocak', 'Şubat', 'Mart', 'Nisan', 'Mayıs', 'Haziran', 'Temmuz', 'Ağustos', 'Eylül', 'Ekim', 'Kasım', 'Aralık'];
const d = new Date(item.date);
const day = String(d.getDate()).padStart(2, '0');
const monthYear = months[d.getMonth()] + ' ' + d.getFullYear();
%>
<div class="note-day"><%= day %></div>
<div class="note-monthyear"><%= monthYear %></div>
<% } %>
<% if (item['reading-time']) { %>
<div class="note-readtime"><%= item['reading-time'] %></div>
<% } %>
</div>
<div class="note-content">
<h2 class="note-title"><a class="note-link" href="<%= item.path %>"><%= item.title %></a></h2>
<% if (item.categories && item.categories.length > 0) { %>
<div class="note-tags">
<% for (const cat of item.categories) { %>
<div class="note-tag"><%= cat %></div>
<% } %>
</div>
<% } %>
<% if (item.description) { %>
<div class="note-desc"><%- item.description %></div>
<% } %>
</div>
</article>
<% } %>
</div>
